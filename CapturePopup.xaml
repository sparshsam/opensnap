<Window x:Class="OpenSnap.CapturePopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenSnap"
        Width="340"
        Height="150"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        MouseDown="OnWindowMouseDown"
        Loaded="OnLoaded">

    <Window.Resources>
        <DropShadowEffect x:Key="PopupShadow"
                          BlurRadius="14"
                          ShadowDepth="4"
                          Direction="270"
                          Opacity="0.35"
                          Color="#000000" />
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#DDD" />
            <Setter Property="Background" Value="#30FFFFFF" />
            <Setter Property="BorderBrush" Value="#20FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Border CornerRadius="10"
            Background="#CC1A1A1A"
            BorderBrush="#40FFFFFF"
            BorderThickness="1"
            Effect="{StaticResource PopupShadow}"
            Padding="14">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title + close hint -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TitleText"
                           Grid.Column="0"
                           Text="Screenshot saved"
                           Foreground="#E0E0E0"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="CloseHint"
                           Grid.Column="1"
                           Text="(auto-closes 5s)"
                           Foreground="#888"
                           FontSize="10"
                           VerticalAlignment="Center" />
            </Grid>

            <!-- Filename -->
            <TextBlock x:Name="FileNameText"
                       Grid.Row="1"
                       Foreground="#AAA"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,10" />

            <!-- Action buttons -->
            <WrapPanel Grid.Row="2">
                <Button x:Name="CopyBtn"   Style="{StaticResource ActionBtn}" Content="Copy"       Tag="Copy"   Click="OnAction" />
                <Button x:Name="OcrBtn"    Style="{StaticResource ActionBtn}" Content="OCR"        Tag="Ocr"    Click="OnAction" />
                <Button x:Name="PaintBtn"  Style="{StaticResource ActionBtn}" Content="Paint"      Tag="Paint"  Click="OnAction" />
                <Button x:Name="RevealBtn" Style="{StaticResource ActionBtn}" Content="Reveal"     Tag="Reveal" Click="OnAction" />
                <Button x:Name="CustomBtn" Style="{StaticResource ActionBtn}" Content="Open with.." Tag="Custom" Click="OnAction" />
            </WrapPanel>
        </Grid>
    </Border>
</Window>
