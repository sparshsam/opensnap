<Window x:Class="OpenSnap.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenSnap Settings"
        Width="380"
        Height="220"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        Topmost="True"
        FontFamily="Segoe UI, sans-serif"
        Loaded="OnLoaded">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Save path -->
        <Label Grid.Row="0" Content="Save folder:" Padding="0,0,0,4" />
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SavePathBox"
                     Grid.Column="0"
                     IsReadOnly="True"
                     Padding="4"
                     BorderBrush="#AAA" />
            <Button Grid.Column="1"
                    Content="Browse…"
                    Width="70"
                    Margin="6,0,0,0"
                    Padding="4,2"
                    Click="OnBrowse" />
        </Grid>

        <!-- Toggles -->
        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <CheckBox x:Name="AlwaysOnTopCheck"
                      Content="Always on top"
                      Margin="0,0,0,6"
                      Checked="OnToggleChanged"
                      Unchecked="OnToggleChanged" />
            <CheckBox x:Name="LaunchAtStartupCheck"
                      Content="Launch at startup"
                      Checked="OnToggleChanged"
                      Unchecked="OnToggleChanged" />
        </StackPanel>

        <!-- Close -->
        <Button Grid.Row="4"
                Content="Close"
                Width="80"
                HorizontalAlignment="Right"
                Padding="6,4"
                Click="OnClose" />
    </Grid>
</Window>
