<Window x:Class="OpenSnap.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenSnap Settings"
        Width="440"
        Height="660"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        Topmost="True"
        FontFamily="Segoe UI, sans-serif"
        Loaded="OnLoaded">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Save path -->
        <Label Grid.Row="0" Content="Save folder:" Padding="0,0,0,4" />
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SavePathBox"
                     Grid.Column="0"
                     IsReadOnly="True"
                     Padding="4"
                     BorderBrush="#AAA" />
            <Button Grid.Column="1"
                    Content="Browse…"
                    Width="70"
                    Margin="6,0,0,0"
                    Padding="4,2"
                    Click="OnBrowse" />
        </Grid>

        <!-- Toggles -->
        <StackPanel Grid.Row="2" Margin="0,10,0,0">
            <CheckBox x:Name="AlwaysOnTopCheck"
                      Content="Always on top"
                      Margin="0,0,0,4"
                      Checked="OnToggleChanged"
                      Unchecked="OnToggleChanged" />
            <CheckBox x:Name="LaunchAtStartupCheck"
                      Content="Launch at startup"
                      Margin="0,0,0,4"
                      Checked="OnToggleChanged"
                      Unchecked="OnToggleChanged" />
            <CheckBox x:Name="PlaySoundCheck"
                      Content="Play capture sound"
                      Margin="0,0,0,4"
                      Checked="OnToggleChanged"
                      Unchecked="OnToggleChanged" />
            <CheckBox x:Name="EdgeSnapCheck"
                      Content="Magnetic edge snapping"
                      Margin="0,0,0,4"
                      Checked="OnToggleChanged"
                      Unchecked="OnToggleChanged" />
            <CheckBox x:Name="AutoHideCheck"
                      Content="Auto-hide when fullscreen app is active"
                      Margin="0,0,0,4"
                      Checked="OnToggleChanged"
                      Unchecked="OnToggleChanged" />
        </StackPanel>

        <!-- Opacity slider -->
        <Border Grid.Row="3" Height="1" Background="#CCC" Margin="0,8,0,8" />
        <Grid Grid.Row="4" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Opacity:" Padding="0,0,8,0" VerticalAlignment="Center" />
            <Slider x:Name="OpacitySlider"
                    Grid.Column="1"
                    Minimum="0.2" Maximum="1.0" TickFrequency="0.05" IsSnapToTickEnabled="True"
                    ValueChanged="OnOpacityChanged"
                    VerticalAlignment="Center" />
            <TextBlock x:Name="OpacityLabel" Grid.Column="2" Text="100%" VerticalAlignment="Center" HorizontalAlignment="Right" />
        </Grid>

        <!-- Separator -->
        <Border Grid.Row="5" Height="1" Background="#CCC" Margin="0,4,0,8" />

        <!-- Hotkeys section -->
        <Label Grid.Row="6" Content="Global hotkeys" FontWeight="SemiBold" Padding="0,0,0,4" />

        <!-- Full screen hotkey -->
        <Grid Grid.Row="7" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Full screen:" Padding="0,0,8,0" VerticalAlignment="Center" />
            <ComboBox x:Name="FullScreenModCombo"
                      Grid.Column="1"
                      Margin="0,0,4,0"
                      Padding="4,2"
                      SelectionChanged="OnHotkeyChanged">
                <ComboBoxItem Tag="8">Win</ComboBoxItem>
                <ComboBoxItem Tag="2">Ctrl</ComboBoxItem>
                <ComboBoxItem Tag="1">Alt</ComboBoxItem>
                <ComboBoxItem Tag="4">Shift</ComboBoxItem>
                <ComboBoxItem Tag="12">Win+Shift</ComboBoxItem>
                <ComboBoxItem Tag="10">Win+Ctrl</ComboBoxItem>
                <ComboBoxItem Tag="9">Win+Alt</ComboBoxItem>
                <ComboBoxItem Tag="6">Ctrl+Shift</ComboBoxItem>
                <ComboBoxItem Tag="3">Ctrl+Alt</ComboBoxItem>
                <ComboBoxItem Tag="5">Alt+Shift</ComboBoxItem>
            </ComboBox>
            <ComboBox x:Name="FullScreenKeyCombo"
                      Grid.Column="2"
                      Padding="4,2"
                      SelectionChanged="OnHotkeyChanged" />
        </Grid>

        <!-- Active window hotkey -->
        <Grid Grid.Row="8" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Active window:" Padding="0,0,8,0" VerticalAlignment="Center" />
            <ComboBox x:Name="ActiveWinModCombo"
                      Grid.Column="1"
                      Margin="0,0,4,0"
                      Padding="4,2"
                      SelectionChanged="OnHotkeyChanged">
                <ComboBoxItem Tag="8">Win</ComboBoxItem>
                <ComboBoxItem Tag="2">Ctrl</ComboBoxItem>
                <ComboBoxItem Tag="1">Alt</ComboBoxItem>
                <ComboBoxItem Tag="4">Shift</ComboBoxItem>
                <ComboBoxItem Tag="12">Win+Shift</ComboBoxItem>
                <ComboBoxItem Tag="10">Win+Ctrl</ComboBoxItem>
                <ComboBoxItem Tag="9">Win+Alt</ComboBoxItem>
                <ComboBoxItem Tag="6">Ctrl+Shift</ComboBoxItem>
                <ComboBoxItem Tag="3">Ctrl+Alt</ComboBoxItem>
                <ComboBoxItem Tag="5">Alt+Shift</ComboBoxItem>
            </ComboBox>
            <ComboBox x:Name="ActiveWinKeyCombo"
                      Grid.Column="2"
                      Padding="4,2"
                      SelectionChanged="OnHotkeyChanged" />
        </Grid>

        <!-- Separator -->
        <Border Grid.Row="9" Height="1" Background="#CCC" Margin="0,6,0,8" />

        <!-- Filename template -->
        <Label Grid.Row="10" Content="Filename template:" Padding="0,0,0,4" />
        <TextBox x:Name="TemplateBox"
                 Grid.Row="11"
                 Padding="4"
                 BorderBrush="#AAA"
                 TextChanged="OnTemplateChanged"
                 VerticalAlignment="Top" />
        <TextBlock Grid.Row="11"
                   Margin="4,28,0,0"
                   Foreground="#888"
                   FontSize="11"
                   Text="Available tokens: {yyyy} {MM} {dd} {HH} {mm} {ss} {HHmmss}" />

        <!-- Close + About -->
        <StackPanel Grid.Row="14" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="About…"
                    Width="70"
                    Padding="6,4"
                    Margin="0,0,8,0"
                    Click="OnAbout" />
            <Button Content="Close"
                    Width="80"
                    Padding="6,4"
                    Click="OnClose" />
        </StackPanel>
    </Grid>
</Window>
