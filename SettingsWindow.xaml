<Window x:Class="OpenSnap.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenSnap Settings"
        Width="440"
        Height="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        Topmost="True"
        FontFamily="Segoe UI, sans-serif"
        Loaded="OnLoaded">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- 0  Save folder label -->
            <RowDefinition Height="Auto" /> <!-- 1  Save path -->
            <RowDefinition Height="Auto" /> <!-- 2  Toggles -->
            <RowDefinition Height="Auto" /> <!-- 3  spacer -->
            <RowDefinition Height="Auto" /> <!-- 4  Opacity -->
            <RowDefinition Height="Auto" /> <!-- 5  spacer -->
            <RowDefinition Height="Auto" /> <!-- 6  Hotkeys label -->
            <RowDefinition Height="Auto" /> <!-- 7  FS hotkey -->
            <RowDefinition Height="Auto" /> <!-- 8  AW hotkey -->
            <RowDefinition Height="Auto" /> <!-- 9  spacer -->
            <RowDefinition Height="Auto" /> <!-- 10 Template label -->
            <RowDefinition Height="Auto" /> <!-- 11 Template -->
            <RowDefinition Height="Auto" /> <!-- 12 spacer -->
            <RowDefinition Height="Auto" /> <!-- 13 Naming -->
            <RowDefinition Height="*" />    <!-- 14 spacer -->
            <RowDefinition Height="Auto" /> <!-- 15 Close+About -->
        </Grid.RowDefinitions>

        <!-- Save path -->
        <Label Grid.Row="0" Content="Save folder:" Padding="0,0,0,4" />
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SavePathBox" Grid.Column="0" IsReadOnly="True" Padding="4" BorderBrush="#AAA" />
            <Button Grid.Column="1" Content="Browse…" Width="70" Margin="6,0,0,0" Padding="4,2" Click="OnBrowse" />
        </Grid>

        <!-- Toggles -->
        <StackPanel Grid.Row="2" Margin="0,10,0,0">
            <CheckBox x:Name="AlwaysOnTopCheck" Content="Always on top" Margin="0,0,0,4" Checked="OnToggleChanged" Unchecked="OnToggleChanged" />
            <CheckBox x:Name="LaunchAtStartupCheck" Content="Launch at startup" Margin="0,0,0,4" Checked="OnToggleChanged" Unchecked="OnToggleChanged" />
            <CheckBox x:Name="PlaySoundCheck" Content="Play capture sound" Margin="0,0,0,4" Checked="OnToggleChanged" Unchecked="OnToggleChanged" />
            <CheckBox x:Name="EdgeSnapCheck" Content="Magnetic edge snapping" Margin="0,0,0,4" Checked="OnToggleChanged" Unchecked="OnToggleChanged" />
            <CheckBox x:Name="AutoHideCheck" Content="Auto-hide when fullscreen app is active" Margin="0,0,0,4" Checked="OnToggleChanged" Unchecked="OnToggleChanged" />
            <CheckBox x:Name="QuickActionsCheck" Content="Show quick-actions popup after capture" Margin="0,0,0,4" Checked="OnToggleChanged" Unchecked="OnToggleChanged" />
            <CheckBox x:Name="SaveOnlyCheck" Content="Save only (don't copy to clipboard)" Margin="0,0,0,4" Checked="OnToggleChanged" Unchecked="OnToggleChanged" />
        </StackPanel>

        <!-- Opacity slider -->
        <Border Grid.Row="3" Height="1" Background="#CCC" Margin="0,8,0,8" />
        <Grid Grid.Row="4" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Opacity:" Padding="0,0,8,0" VerticalAlignment="Center" />
            <Slider x:Name="OpacitySlider" Grid.Column="1" Minimum="0.2" Maximum="1.0" TickFrequency="0.05" IsSnapToTickEnabled="True" ValueChanged="OnOpacityChanged" VerticalAlignment="Center" />
            <TextBlock x:Name="OpacityLabel" Grid.Column="2" Text="100%" VerticalAlignment="Center" HorizontalAlignment="Right" />
        </Grid>

        <!-- ── Hotkeys ── -->
        <Border Grid.Row="5" Height="1" Background="#CCC" Margin="0,4,0,8" />
        <Label Grid.Row="6" Content="Global hotkeys" FontWeight="SemiBold" Padding="0,0,0,4" />

        <Grid Grid.Row="7" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Full screen:" Padding="0,0,8,0" VerticalAlignment="Center" />
            <ComboBox x:Name="FullScreenModCombo" Grid.Column="1" Margin="0,0,4,0" Padding="4,2" SelectionChanged="OnHotkeyChanged">
                <ComboBoxItem Tag="8">Win</ComboBoxItem>
                <ComboBoxItem Tag="2">Ctrl</ComboBoxItem>
                <ComboBoxItem Tag="1">Alt</ComboBoxItem>
                <ComboBoxItem Tag="4">Shift</ComboBoxItem>
                <ComboBoxItem Tag="12">Win+Shift</ComboBoxItem>
                <ComboBoxItem Tag="10">Win+Ctrl</ComboBoxItem>
                <ComboBoxItem Tag="9">Win+Alt</ComboBoxItem>
                <ComboBoxItem Tag="6">Ctrl+Shift</ComboBoxItem>
                <ComboBoxItem Tag="3">Ctrl+Alt</ComboBoxItem>
                <ComboBoxItem Tag="5">Alt+Shift</ComboBoxItem>
            </ComboBox>
            <ComboBox x:Name="FullScreenKeyCombo" Grid.Column="2" Padding="4,2" SelectionChanged="OnHotkeyChanged" />
        </Grid>

        <Grid Grid.Row="8" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Active window:" Padding="0,0,8,0" VerticalAlignment="Center" />
            <ComboBox x:Name="ActiveWinModCombo" Grid.Column="1" Margin="0,0,4,0" Padding="4,2" SelectionChanged="OnHotkeyChanged">
                <ComboBoxItem Tag="8">Win</ComboBoxItem>
                <ComboBoxItem Tag="2">Ctrl</ComboBoxItem>
                <ComboBoxItem Tag="1">Alt</ComboBoxItem>
                <ComboBoxItem Tag="4">Shift</ComboBoxItem>
                <ComboBoxItem Tag="12">Win+Shift</ComboBoxItem>
                <ComboBoxItem Tag="10">Win+Ctrl</ComboBoxItem>
                <ComboBoxItem Tag="9">Win+Alt</ComboBoxItem>
                <ComboBoxItem Tag="6">Ctrl+Shift</ComboBoxItem>
                <ComboBoxItem Tag="3">Ctrl+Alt</ComboBoxItem>
                <ComboBoxItem Tag="5">Alt+Shift</ComboBoxItem>
            </ComboBox>
            <ComboBox x:Name="ActiveWinKeyCombo" Grid.Column="2" Padding="4,2" SelectionChanged="OnHotkeyChanged" />
        </Grid>

        <!-- ── Naming ── -->
        <Border Grid.Row="9" Height="1" Background="#CCC" Margin="0,6,0,8" />
        <Label Grid.Row="10" Content="Filename template:" Padding="0,0,0,4" />
        <TextBox x:Name="TemplateBox" Grid.Row="11" Padding="4" BorderBrush="#AAA" TextChanged="OnTemplateChanged" VerticalAlignment="Top" />
        <TextBlock Grid.Row="11" Margin="4,28,0,0" Foreground="#888" FontSize="11"
                   Text="Tokens: {yyyy} {MM} {dd} {HH} {mm} {ss} {HHmmss} {seq} {prefix}" />

        <Border Grid.Row="12" Height="1" Background="#CCC" Margin="0,8,0,8" />

        <Grid Grid.Row="13" Margin="0,0,0,6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0" Grid.Column="0" Content="Project prefix:" Padding="0,0,8,4" VerticalAlignment="Center" />
            <TextBox x:Name="PrefixBox" Grid.Row="0" Grid.Column="1" Padding="4" BorderBrush="#AAA" TextChanged="OnNamingChanged" />

            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,4,0,0">
                <CheckBox x:Name="SeqNumberCheck" Content="Sequential numbering" Margin="0,0,0,4" Checked="OnToggleChanged" Unchecked="OnToggleChanged" />
                <CheckBox x:Name="DateFoldersCheck" Content="Date-based subfolders (yyyy/MM-yyyy)" Margin="0,0,0,4" Checked="OnToggleChanged" Unchecked="OnToggleChanged" />
                <CheckBox x:Name="LargeIconsCheck" Content="Larger icons" Margin="0,0,0,4" Checked="OnToggleChanged" Unchecked="OnToggleChanged" />
            </StackPanel>

            <Label Grid.Row="2" Grid.Column="0" Content="Open with app:" Padding="0,8,8,4" VerticalAlignment="Center" />
            <Grid Grid.Row="2" Grid.Column="1" Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="CustomAppBox" Grid.Column="0" Padding="4" BorderBrush="#AAA" TextChanged="OnNamingChanged" />
                <Button Grid.Column="1" Content="Browse…" Width="70" Margin="6,0,0,0" Padding="4,2" Click="OnBrowseApp" />
            </Grid>

            <Label Grid.Row="3" Grid.Column="0" Content="Language:" Padding="0,8,8,4" VerticalAlignment="Center" />
            <ComboBox x:Name="LangCombo" Grid.Row="3" Grid.Column="1" Margin="0,6,0,0" Padding="4,2" SelectionChanged="OnLangChanged" />
        </Grid>

        <!-- Close + About -->
        <StackPanel Grid.Row="15" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="About…" Width="70" Padding="6,4" Margin="0,0,8,0" Click="OnAbout" />
            <Button Content="Close" Width="80" Padding="6,4" Click="OnClose" />
        </StackPanel>
    </Grid>
</Window>
