<Window x:Class="OpenSnap.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About OpenSnap"
        Width="320"
        Height="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        FontFamily="Segoe UI, sans-serif">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- App name + icon -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Viewbox Width="28" Height="28" Stretch="Uniform" Margin="0,0,10,0" VerticalAlignment="Center">
                <Path Fill="#4A9EFF"
                      Data="M12,3.5 L14.5,3.5 L16,6.5 L20,6.5 C21.1,6.5 22,7.4 22,8.5 L22,18.5 C22,19.6 21.1,20.5 20,20.5 L4,20.5 C2.9,20.5 2,19.6 2,18.5 L2,8.5 C2,7.4 2.9,6.5 4,6.5 L8,6.5 L9.5,3.5 Z M12,9.5 C9.8,9.5 8,11.3 8,13.5 C8,15.7 9.8,17.5 12,17.5 C14.2,17.5 16,15.7 16,13.5 C16,11.3 14.2,9.5 12,9.5 Z" />
            </Viewbox>
            <StackPanel>
                <TextBlock Text="OpenSnap" FontSize="16" FontWeight="SemiBold" />
                <TextBlock x:Name="VersionText" FontSize="12" Foreground="#888" />
            </StackPanel>
        </StackPanel>

        <!-- Description -->
        <TextBlock Grid.Row="1" TextWrapping="Wrap" Margin="0,0,0,12" FontSize="12">
            A minimal, always-on-top screenshot widget for Windows.
            Capture full screen, active window, or a selected area —
            all in one click.
        </TextBlock>

        <!-- GitHub link -->
        <TextBlock Grid.Row="2" Margin="0,0,0,4">
            <Hyperlink NavigateUri="https://github.com/sparshsam/opensnap"
                       RequestNavigate="OnGitHubLink">
                github.com/sparshsam/opensnap
            </Hyperlink>
        </TextBlock>

        <!-- Copyright -->
        <TextBlock Grid.Row="3" Text="© Sparsh" FontSize="11" Foreground="#888" />

        <!-- License -->
        <TextBlock Grid.Row="4" TextWrapping="Wrap" FontSize="11" Foreground="#888"
                   Margin="0,8,0,0">
            Licensed under the MIT License. See LICENSE on GitHub for details.
        </TextBlock>

        <!-- Close -->
        <Button Grid.Row="5"
                Content="Close"
                Width="80"
                Height="26"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Click="OnClose" />
    </Grid>
</Window>
