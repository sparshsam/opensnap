<Window x:Class="OpenSnap.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About OpenSnap"
        Width="420"
        Height="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        FontFamily="Segoe UI, sans-serif">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Viewbox Width="28" Height="28" Stretch="Uniform" Margin="0,0,10,0" VerticalAlignment="Center">
                <Path Fill="#4A9EFF"
                      Data="M12,3.5 L14.5,3.5 L16,6.5 L20,6.5 C21.1,6.5 22,7.4 22,8.5 L22,18.5 C22,19.6 21.1,20.5 20,20.5 L4,20.5 C2.9,20.5 2,19.6 2,18.5 L2,8.5 C2,7.4 2.9,6.5 4,6.5 L8,6.5 L9.5,3.5 Z M12,9.5 C9.8,9.5 8,11.3 8,13.5 C8,15.7 9.8,17.5 12,17.5 C14.2,17.5 16,15.7 16,13.5 C16,11.3 14.2,9.5 12,9.5 Z" />
            </Viewbox>
            <StackPanel>
                <TextBlock Text="OpenSnap" FontSize="16" FontWeight="SemiBold" />
                <TextBlock x:Name="VersionText" FontSize="12" Foreground="#888" />
                <TextBlock x:Name="UpdateStatusText" FontSize="11" Foreground="#4A9EFF" />
            </StackPanel>
        </StackPanel>

        <!-- Tab control -->
        <TabControl Grid.Row="1">
            <TabItem Header="About">
                <StackPanel Margin="0,8,0,0">
                    <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,8">
                        A minimal, always-on-top screenshot widget for Windows.
                        Capture full screen, active window, or a selected area.
                    </TextBlock>
                    <TextBlock Margin="0,0,0,4">
                        <Hyperlink NavigateUri="https://github.com/sparshsam/opensnap"
                                   RequestNavigate="OnGitHubLink">
                            github.com/sparshsam/opensnap
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Text="© Sparsh" FontSize="11" Foreground="#888" Margin="0,0,0,4" />
                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#888">
                        Licensed under the MIT License.
                    </TextBlock>
                </StackPanel>
            </TabItem>

            <TabItem Header="Changelog">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBox x:Name="ChangelogBox"
                             Grid.Row="0"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas, Courier New"
                             FontSize="11"
                             Padding="6"
                             BorderBrush="#AAA" />
                    <Button Grid.Row="1"
                            Content="View full release on GitHub"
                            Width="180"
                            Height="24"
                            Margin="0,6,0,0"
                            HorizontalAlignment="Left"
                            Click="OnGitHubReleases" />
                </Grid>
            </TabItem>

            <TabItem Header="Diagnostics">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBox x:Name="DiagBox"
                             Grid.Row="0"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas, Courier New"
                             FontSize="11"
                             Padding="6"
                             BorderBrush="#AAA" />
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                        <Button Content="Copy diagnostics"
                                Width="120" Height="24" Margin="0,0,8,0"
                                Click="OnCopyDiagnostics" />
                        <Button x:Name="ExportLogBtn"
                                Content="Export logs"
                                Width="100" Height="24"
                                Click="OnExportLogs" />
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Close -->
        <Button Grid.Row="2"
                Content="Close"
                Width="80"
                Height="26"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,10,0,0"
                Click="OnClose" />
    </Grid>
</Window>
