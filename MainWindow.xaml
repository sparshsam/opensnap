<Window x:Class="OpenShot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenShot"
        Width="80"
        Height="36"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Loaded="OnLoaded"
        PreviewMouseLeftButtonDown="OnPreviewMouseDown"
        PreviewMouseMove="OnPreviewMouseMove"
        PreviewMouseLeftButtonUp="OnPreviewMouseUp">

    <Window.Resources>
        <DropShadowEffect x:Key="WidgetShadow"
                          BlurRadius="14"
                          ShadowDepth="4"
                          Direction="270"
                          Opacity="0.40"
                          Color="#000000" />
    </Window.Resources>

    <!-- Single unified dark capsule — click anywhere to capture, drag anywhere to move -->
    <Border x:Name="RootCapsule"
            Width="80"
            Height="36"
            Background="#2B2B2B"
            CornerRadius="18"
            BorderBrush="#555555"
            BorderThickness="1"
            Effect="{StaticResource WidgetShadow}"
            Cursor="Hand"
            Padding="0">

        <!-- Camera icon centred in the capsule -->
        <Viewbox Width="18"
                 Height="18"
                 Stretch="Uniform"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">
            <Path Fill="#C0C0C0"
                  Data="M12,3.5 L14.5,3.5 L16,6.5 L20,6.5 C21.1,6.5 22,7.4 22,8.5 L22,18.5 C22,19.6 21.1,20.5 20,20.5 L4,20.5 C2.9,20.5 2,19.6 2,18.5 L2,8.5 C2,7.4 2.9,6.5 4,6.5 L8,6.5 L9.5,3.5 Z M12,9.5 C9.8,9.5 8,11.3 8,13.5 C8,15.7 9.8,17.5 12,17.5 C14.2,17.5 16,15.7 16,13.5 C16,11.3 14.2,9.5 12,9.5 Z" />
        </Viewbox>
    </Border>
</Window>
