<Window x:Class="OpenShot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenShot"
        Width="80"
        Height="36"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Loaded="OnLoaded"
        PreviewMouseLeftButtonDown="OnPreviewMouseDown"
        PreviewMouseMove="OnPreviewMouseMove"
        PreviewMouseLeftButtonUp="OnPreviewMouseUp">

    <Window.Resources>
        <DropShadowEffect x:Key="WidgetShadow"
                          BlurRadius="14"
                          ShadowDepth="4"
                          Direction="270"
                          Opacity="0.40"
                          Color="#000000" />
    </Window.Resources>

    <!-- Single unified dark capsule — the entire surface is the action target -->
    <Border x:Name="RootCapsule"
            Width="80"
            Height="36"
            Background="#2B2B2B"
            CornerRadius="18"
            BorderBrush="#555555"
            BorderThickness="1"
            Effect="{StaticResource WidgetShadow}"
            Cursor="Hand">

        <!-- Camera icon centered as the identity mark -->
        <Viewbox Width="17"
                 Height="17"
                 Stretch="Uniform"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">
            <Path Fill="#C0C0C0"
                  Data="M9,3 L12,3 L13,6 L18,6 C19,6 20,7 20,8 L20,17 C20,18 19,19 18,19 L6,19 C5,19 4,18 4,17 L4,8 C4,7 5,6 6,6 L11,6 L12,3 Z M12,9 C10,9 9,10 9,12 C9,14 10,15 12,15 C14,15 15,14 15,12 C15,10 14,9 12,9 Z" />
        </Viewbox>
    </Border>
</Window>
