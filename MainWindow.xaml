<Window x:Class="OpenShot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenShot"
        Width="130"
        Height="42"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Loaded="OnLoaded"
        MouseLeftButtonDown="OnMouseDown">

    <Border Background="#2D2D2D"
            CornerRadius="21"
            BorderBrush="#555555"
            BorderThickness="1"
            Padding="0">
        <Grid Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- App badge / drag handle -->
            <Border Grid.Column="0"
                    Background="#3A3A3A"
                    CornerRadius="21,0,0,21"
                    Width="42"
                    Cursor="Hand">
                <TextBlock Text="OS"
                           Foreground="#999999"
                           FontSize="11"
                           FontWeight="SemiBold"
                           FontFamily="Segoe UI, sans-serif"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>

            <!-- Camera icon capture button -->
            <Button x:Name="CaptureButton"
                    Grid.Column="1"
                    Width="88"
                    Height="42"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="OnCaptureClick"
                    ToolTip="Capture screenshot">
                <Button.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="0,21,21,0">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border"
                                                    Property="Background"
                                                    Value="#3A3A3A" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border"
                                                    Property="Background"
                                                    Value="#4A4A4A" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Resources>

                <!-- Camera icon (SVG path) -->
                <Viewbox Width="18" Height="18" Stretch="Uniform">
                    <Path Fill="#CCCCCC"
                          Data="M9,3 L12,3 L13,6 L18,6 C19,6 20,7 20,8 L20,17 C20,18 19,19 18,19 L6,19 C5,19 4,18 4,17 L4,8 C4,7 5,6 6,6 L11,6 L12,3 Z M12,9 C10,9 9,10 9,12 C9,14 10,15 12,15 C14,15 15,14 15,12 C15,10 14,9 12,9 Z" />
                </Viewbox>
            </Button>

            <!-- Feedback toast (hidden by default) -->
            <TextBlock x:Name="FeedbackLabel"
                       Grid.Column="1"
                       Text="Saved + copied"
                       Foreground="#4A9EFF"
                       FontSize="10"
                       FontFamily="Segoe UI, sans-serif"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Opacity="0"
                       IsHitTestVisible="False" />
        </Grid>
    </Border>
</Window>
